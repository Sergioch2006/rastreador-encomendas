  },
  "Jwt": {
    "Issuer": "GlobalLogistics.AuthAPI",
    "Audience": "GlobalLogistics.API",
    "SigningKey": "HeAwCqSEvdyn8GSuDXYXZhygQ0htwqz2vGbQ/5P9giU=",
    "TokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  }
